{
  "name": "beet-frontend",
  "scripts": {
    "build:client": "esbuild src/client.ts --bundle --outfile=public/client.js",
    "build:server": "esbuild src/server.ts --bundle --platform=node --outfile=public/server.js --external:node-pty",
    "build": "npm run build:client && npm run build:server",
    "start": "node public/server.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.17",
    "busboy": "^1.6.0",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/busboy": "^1.5.4",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
